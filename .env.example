# ──────────────────────────────────────────────────
# Pinto Chat Adapter – Environment Variables
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────────

# ── Fallback bot id ──
# Preferred durable config is ~/.hermes/config.yaml:
# platforms.pinto.extra.botId: your-pinto-bot-id
# Use PINTO_BOT_ID only for standalone or first-start fallback.
PINTO_BOT_ID=your-pinto-bot-id

# ── API ──
# PINTO_API_URL=https://api.pinto-app.com          # Production (default)
# PINTO_API_URL=https://api-dev.pinto-app.com       # Development

# ── Webhook ──
# PINTO_WEBHOOK_SECRET=your-optional-secret-here
# PINTO_WEBHOOK_PATH=/plugins/pinto/webhook

# ── Access Control ──
# PINTO_ALLOWED_USERS=user-id-1,user-id-2
# PINTO_ALLOW_ALL_USERS=true

# ── Cron / Notifications ──
# PINTO_HOME_CHANNEL=default-chat-id-for-cron

# ── Standalone Server Only ──
# PINTO_EMAIL=you@example.com
# PINTO_PASSWORD=your-password
# PINTO_WEBHOOK_PORT=18789
# HERMES_API_URL=http://127.0.0.1:18789
# API_SERVER_KEY=your-hermes-api-key
